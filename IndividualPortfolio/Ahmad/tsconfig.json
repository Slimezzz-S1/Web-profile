{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "jsx": "react",             // Tells TS to compile JSX/TSX tags into function calls
    "jsxFactory": "h",          // Change the default 'React.createElement' to a function named 'h'
    "lib": ["DOM", "ES2022"],
    "strict": true
  }
}